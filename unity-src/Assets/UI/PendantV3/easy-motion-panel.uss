/* Pendant V3 - Easy Motion: Phase 2B-1 preset poses and gripper shortcuts */
.rc-easy-root {
    flex-grow: 1;
    flex-direction: column;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
}

.rc-easy-header {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    min-width: 0;
}

.rc-easy-badge {
    padding-left: 8px;
    padding-right: 8px;
    padding-top: 3px;
    padding-bottom: 3px;
    border-radius: var(--rc-radius-pill);
    background-color: var(--rc-button-bg-success-soft);
    color: var(--rc-success);
    font-size: 12px;
}

.rc-easy-section-title {
    margin-top: 8px;
    font-size: 12px;
    color: var(--rc-muted-text);
    -unity-font-style: bold;
}

.rc-easy-section-title--spaced {
    margin-top: 16px;
}

.rc-easy-preset-grid {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 8px;
    min-width: 0;
    max-width: 100%;
}

.rc-easy-preset-button {
    flex-grow: 1;
    width: 46%;
    min-width: 84px;
    min-height: 64px;
    margin-right: 6px;
    margin-bottom: 6px;
    padding-top: 6px;
    padding-bottom: 6px;
    font-size: 11px;
    white-space: normal;
    -unity-text-align: middle-center;
    background-color: var(--rc-button-bg);
    color: var(--rc-button-text);
}

.rc-easy-gripper-control-host {
    margin-top: 8px;
}

.rc-easy-gripper-title {
    margin-bottom: 4px;
    font-size: 12px;
    color: var(--rc-text);
    -unity-font-style: bold;
}

.rc-easy-gripper-status {
    margin-bottom: 4px;
    font-size: 11px;
    color: var(--rc-muted-text);
}

.rc-easy-gripper-meta {
    margin-bottom: 4px;
    font-size: 10px;
    color: var(--rc-muted-text);
}

.rc-easy-gripper-gate {
    margin-top: 4px;
    margin-bottom: 4px;
    padding: 6px;
    border-radius: var(--rc-radius-md);
    background-color: var(--rc-surface-row-strong);
    font-size: 10px;
    color: var(--rc-warning);
    white-space: normal;
}

.rc-easy-gripper-slider {
    margin-top: 6px;
    min-height: 28px;
}

.rc-easy-control-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 6px;
}

.rc-easy-number-field {
    flex-grow: 1;
    min-width: 88px;
    margin-right: 6px;
}

.rc-easy-quick-button {
    min-width: 70px;
}

.rc-easy-option-card {
    margin-top: 10px;
    padding: 8px;
    border-radius: var(--rc-radius-xl);
    background-color: var(--rc-surface-row-strong);
    min-width: 0;
    max-width: 100%;
}

.rc-easy-hint {
    margin-top: 6px;
    font-size: 11px;
    color: var(--rc-muted-text);
}

.rc-easy-exec-row {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 12px;
}

.rc-easy-action-button {
    flex-grow: 1;
    min-width: 84px;
    min-height: 34px;
    margin-right: 6px;
    margin-bottom: 6px;
    font-size: 11px;
}

.rc-easy-action-button--primary {
    background-color: var(--rc-button-bg-success);
    color: var(--rc-button-text-strong);
}

.rc-easy-action-button--danger {
    background-color: var(--rc-button-bg-danger);
    color: var(--rc-button-text-strong);
}
