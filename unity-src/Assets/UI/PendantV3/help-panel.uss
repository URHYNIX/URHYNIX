/* Pendant V3 - Help Panel: Phase 2D minimum context help scaffold */
.rc-help-root {
    flex-grow: 1;
}

.rc-help-card {
    margin-top: 10px;
    padding: 10px;
    border-radius: var(--rc-radius-lg);
    background-color: var(--rc-surface-soft);
}

.rc-help-subtitle {
    font-size: 13px;
    -unity-font-style: bold;
    color: var(--rc-title-text);
}
